meta {
  name: Reset Password
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/api/v1/auth/reset-password
  body: json
  auth: none
}

body:json {
  {
    "token": "E_POSTADAKI_TOKEN",
    "newPassword": "YeniSifre123"
  }
}

docs {
  E-postadaki baglantida gelen token ile yeni sifre belirler.
  token: reset linkindeki ?token=... degeri.
  Basarili olunca kullanicinin tum oturumlari kapanir; yeni sifreyle
  /login uzerinden tekrar giris yapilir. Token tek kullanimliktir.
}
