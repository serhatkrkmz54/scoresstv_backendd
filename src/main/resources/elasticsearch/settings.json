{
  "analysis": {
    "tokenizer": {
      "autocomplete_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 15,
        "token_chars": ["letter", "digit"]
      }
    },
    "filter": {
      "scorestv_asciifolding": {
        "type": "asciifolding",
        "preserve_original": true
      }
    },
    "analyzer": {
      "autocomplete_index": {
        "type": "custom",
        "tokenizer": "autocomplete_tokenizer",
        "filter": ["lowercase", "scorestv_asciifolding"]
      },
      "autocomplete_search": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase", "scorestv_asciifolding"]
      }
    }
  }
}
